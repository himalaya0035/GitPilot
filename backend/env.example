# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/GitPilot
DB_NAME=GitPilot
COLLECTION_NAME=workflows

# Environment
NODE_ENV=development

# Optional: MongoDB Atlas (for production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/GitPilot?retryWrites=true&w=majority

# Optional: Enable MongoDB adapter (if not set, will use Memory adapter)
# USE_MONGODB=true